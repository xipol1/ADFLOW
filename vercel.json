{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "installCommand": "npm install --include=dev",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "routes/**,controllers/**,models/**,middleware/**,lib/**,services/**,config/**,docs/swagger/**,templates/**,integraciones/**,jobs/**",
      "excludeFiles": "node_modules/sharp/**,node_modules/puppeteer/**,node_modules/puppeteer-core/**,node_modules/whatsapp-web.js/**"
    }
  },
  "crons": [
    {
      "path": "/api/oauth/meta/cron-refresh",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/admin/scoring/run",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/admin/metrics/capture",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/jobs/telegram-intel",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/jobs/tgstat-discover",
      "schedule": "0 5 * * 1"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    },
    {
      "source": "/blog/feed.xml",
      "headers": [{ "key": "Content-Type", "value": "application/rss+xml; charset=utf-8" }]
    },
    {
      "source": "/blog/(.*).html",
      "headers": [{ "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=86400" }]
    },
    {
      "source": "/blog/index.html",
      "headers": [{ "key": "Cache-Control", "value": "public, s-maxage=1800, stale-while-revalidate=3600" }]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/t/:code", "destination": "/api/index.js" },
    { "source": "/r/:campaignId", "destination": "/api/index.js" },
    { "source": "/go/:path*", "destination": "/api/index.js" },
    { "source": "/health", "destination": "/api/index.js" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/feed.xml", "destination": "/blog/feed.xml" },
    { "source": "/blog/calculadora-precios-publicidad", "destination": "/index.html" },
    { "source": "/blog/:slug", "destination": "/blog/:slug.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
