{
  "version": 2,
  "cleanUrls": false,
  "trailingSlash": false,
  "installCommand": "npm install --include=dev",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "routes/**,controllers/**,models/**,middleware/**,lib/**,services/**,config/**,docs/swagger/**,templates/**,integraciones/**,jobs/**",
      "excludeFiles": "node_modules/sharp/**,node_modules/puppeteer/**,node_modules/puppeteer-core/**,node_modules/whatsapp-web.js/**,channelad-remotion-video/**"
    }
  },
  "crons": [
    {
      "path": "/api/oauth/meta/cron-refresh",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/oauth/channels/cron-health",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/admin/scoring/run",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/admin/metrics/capture",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/jobs/telegram-intel",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/jobs/tgstat-discover",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/jobs/multiplatform-intel",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/jobs/swaps-maintenance",
      "schedule": "15 4 * * *"
    },
    {
      "path": "/api/jobs/auth-cleanup",
      "schedule": "30 4 * * *"
    }
  ],
  "headers": [
    {
      "source": "/((?!assets/|api/|blog).*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/blog/feed.xml",
      "headers": [{ "key": "Content-Type", "value": "application/rss+xml; charset=utf-8" }]
    },
    {
      "source": "/blog/(.*).html",
      "headers": [{ "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=86400" }]
    },
    {
      "source": "/blog/index.html",
      "headers": [{ "key": "Cache-Control", "value": "public, s-maxage=1800, stale-while-revalidate=3600" }]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/t/:code", "destination": "/api/index.js" },
    { "source": "/r/:campaignId", "destination": "/api/index.js" },
    { "source": "/go/:path*", "destination": "/api/index.js" },
    { "source": "/health", "destination": "/api/index.js" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/feed.xml", "destination": "/blog/feed.xml" },
    { "source": "/blog/calculadora-precios-publicidad", "destination": "/blog/calculadora-precios-publicidad.html" },
    { "source": "/blog/:slug", "destination": "/blog/:slug.html" },
    { "source": "/para-anunciantes", "destination": "/para-anunciantes.html" },
    { "source": "/para-canales", "destination": "/para-canales.html" },
    { "source": "/marketplace", "destination": "/marketplace.html" },
    { "source": "/explore", "destination": "/explore.html" },
    { "source": "/rankings", "destination": "/rankings.html" },
    { "source": "/herramientas", "destination": "/herramientas.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/que-es-channelad", "destination": "/que-es-channelad.html" },
    { "source": "/sobre-nosotros", "destination": "/sobre-nosotros.html" },
    { "source": "/soporte", "destination": "/soporte.html" },
    { "source": "/privacidad", "destination": "/privacidad.html" },
    { "source": "/terminos", "destination": "/terminos.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
