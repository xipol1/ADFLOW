# Files excluded from the Vercel deploy bundle.
# Anything matched here is dropped from the deployment artefact (smaller cold
# start, less risk of secrets leaking through static serving).

node_modules
.git
.github
.vercel
.claude

# Environment files (Vercel reads env from project settings, never from disk)
.env
.env.*
!.env.example

# Logs
*.log
_server_fatal.log

# Local archives / planning artefacts (already gitignored, but defence in depth)
*.zip
*.xlsx
*.xls
*.docx
*.pdf
Adflow 1.0/
adflow-unified/
Adflow-1.0-clone/
Adflow Gestion/
plataforma-*/

# Tests and docs are not needed at runtime
tests/
docs/
AUDIT.md

# Local user uploads (production should use object storage)
uploads/

# Editor / OS noise
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Local-only state
settings.local.json
