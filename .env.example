# ──────────────────────────────────────────────────────────────────────────────
#  Channelad — example environment file
# ──────────────────────────────────────────────────────────────────────────────
#  Copy to .env and fill in the values. .env is gitignored.
#  In Vercel, set the same keys in the project settings (Production / Preview).
#
#  Variables marked [required-prod] block startup in production
#  (validated by config/validateEnv.js with strict=true).
#
#  Variables marked [required-feature] are needed only if you enable that
#  feature; missing them produces a 503 on the affected endpoints.
# ──────────────────────────────────────────────────────────────────────────────


# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development           # development | production | test
PORT=5000                      # Express HTTP port (server.js)
HOST=0.0.0.0                   # bind address
APP_NAME=Channelad             # cosmetic, used in logs


# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173            # Vite dev URL or production origin
BACKEND_URL=http://localhost:5000             # used by email links / OAuth callbacks
VITE_API_URL=                                 # frontend → backend base (empty = same origin)
PUBLIC_BASE_URL=https://channelad.io          # public origin used in tracking-link redirects (swaps, etc.)


# ── Database (MongoDB) ────────────────────────────────────────────────────────
# [required-prod]
MONGODB_URI=mongodb://localhost:27017/channelad
# Fallback name accepted by server.js when MONGODB_URI is missing
# DATABASE_URL=
MONGODB_TEST_URI=mongodb://localhost:27017/channelad_test


# ── Authentication ────────────────────────────────────────────────────────────
# [required-prod] JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_use_a_long_random_string
JWT_REFRESH_SECRET=change_me_too_a_different_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=channelad
JWT_AUDIENCE=channelad

# bcrypt cost factor for password hashing (10 = ~10ms, 12 = ~150ms — recommended for 2026)
BCRYPT_ROUNDS=12


# ── Stripe ────────────────────────────────────────────────────────────────────
# [required-feature] Without these, payment endpoints fall back to "simulated" mode.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# [CRITICAL] If missing, the /api/transacciones/webhook handler returns 503
# (no payment confirmations get processed). MUST be set in production and
# must match the signing secret of the live Stripe webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=eur                          # eur | usd | gbp …  (code defaults to "eur")

# Subscription billing (Fase 2). Separate webhook endpoint + signing secret
# so plan lifecycle events don't share a queue with campaign payments.
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=whsec_...
# Price IDs are provisioned by scripts/setup-stripe-subscription-products.js;
# paste them here after the first run (the script prints them).
STRIPE_PRICE_CREATOR_PRO_MONTHLY=price_...
STRIPE_PRICE_CREATOR_PRO_ANNUAL=price_...
STRIPE_PRICE_ADVERTISER_PRO_MONTHLY=price_...
STRIPE_PRICE_ADVERTISER_PRO_ANNUAL=price_...
# Frontend redirects after Stripe-hosted Checkout / Customer Portal flows.
STRIPE_CHECKOUT_SUCCESS_URL=https://channelad.io/account/billing?status=success
STRIPE_CHECKOUT_CANCEL_URL=https://channelad.io/pricing?status=cancelled
STRIPE_PORTAL_RETURN_URL=https://channelad.io/account/billing


# ── Commission tiers ──────────────────────────────────────────────────────────
# Commission rates are NOT configured via env. They live in config/commissions.js
# (standard 20%, partnerAPI 18%, autoCampaign 25%, collaborative 28%, volumeMid 18%,
# volumeHigh 15%). Edit that file to change them; do not add a PLATFORM_COMMISSION_RATE
# env var — it is not read anywhere.


# ── Email (transactional) ─────────────────────────────────────────────────────
# Provider hint: gmail | outlook | sendgrid | mailgun | smtp
EMAIL_PROVIDER=smtp
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_SECURE=true                           # true for 465, false for 587
EMAIL_USER=contact@example.com
EMAIL_PASS=replace_with_smtp_password
EMAIL_FROM_NAME=Channelad
EMAIL_FROM_ADDRESS=noreply@channelad.io
SUPPORT_EMAIL=support@channelad.io


# ── File uploads ──────────────────────────────────────────────────────────────
MAX_REQUEST_SIZE=10mb                       # body parser limit (express.json / urlencoded)
MAX_FILE_SIZE=10485760                      # bytes — multer per-file ceiling (10 MB)
UPLOADS_PATH=./uploads                      # NOTE: UPLOADS_PATH (with S), not UPLOAD_PATH
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf


# ── Redis (rate-limit + WhatsApp OTP TTL) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379


# ── Security extras ───────────────────────────────────────────────────────────
# AES-256 key for encrypting stored OAuth/2FA secrets — MUST be exactly 32 chars
ENCRYPTION_KEY=replace_with_32_char_random_string_!
SESSION_SECRET=replace_with_long_random_string

# Vercel cron jobs validate this header before running scoring/intel jobs.
# Vercel auto-injects it in production; set it manually for local dev.
CRON_SECRET=replace_with_random_cron_secret

# In-process background job scheduler (lib/jobScheduler.js). Set to "true" on
# EXACTLY ONE always-on machine (the Fly worker) to run the heavy scraper/metric
# jobs that can't finish inside Vercel's 60s serverless timeout. Leave unset/false
# on Vercel and any extra machines — the scheduler is a no-op unless this is "true".
ENABLE_BACKGROUND_JOBS=false

# Comma-separated allowlist for CORS (production). Origins not in this list and
# not matching *.vercel.app are rejected.
CORS_ORIGIN=http://localhost:5173,https://channelad.io


# ── Telegram ──────────────────────────────────────────────────────────────────
# [required-feature] Bot used for channel verification and onboarding
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_BOT_USERNAME=channelad_calculator_bot

# [required-feature] Secret token passed in setWebhook(...secret_token=…).
# /api/webhooks/telegram only accepts requests that present this token in the
# X-Telegram-Bot-Api-Secret-Token header. Without it the endpoint would let
# anyone POST fake CampaignMetrics views.
TELEGRAM_WEBHOOK_SECRET=replace_with_random_secret_min_32_chars

# MTProto API for channel intelligence scraping (https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Generated with: node scripts/generateTelegramSession.js
TELEGRAM_SESSION=

# Optional channel where the platform pushes daily stats
TELEGRAM_STATS_CHANNEL_ID=


# ── WhatsApp Business (Cloud API + whatsapp-web.js) ───────────────────────────
# [required-feature]
WHATSAPP_TOKEN=replace_me_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=replace_me
WHATSAPP_VERIFY_TOKEN=replace_with_random_string_for_meta_webhook_subscribe
WHATSAPP_CHANNELAD_NUMBER=+34600000000

# Local path for whatsapp-web.js admin worker (only set on a long-running host;
# leave empty on Vercel to skip the worker startup).
WHATSAPP_SESSION_PATH=

# ── Baileys sidecar (newsletter verification) ─────────────────────────────────
# Baileys needs a persistent Node process — won't run on Vercel serverless.
# In production deploy the Channelad backend image to Fly.io as a sidecar and
# set BOTH envs below to the sidecar URL. Backend uses BAILEYS_SIDECAR_URL to
# flip the /api/features.whatsapp flag on; frontend uses VITE_BAILEYS_API_URL
# to route /baileys/* HTTP calls to the sidecar instead of the Vercel function
# (see client/src/services/api.js). They MUST point at the same host.
#
# Deploy steps: docs/BAILEYS_SIDECAR_PLAN.md
BAILEYS_SIDECAR_URL=
VITE_BAILEYS_API_URL=

# Baileys ownership trust gate (BETA FREEZE — default OFF).
# Invite/role-based ownership is not yet sound (LID-vs-phone owner match,
# missing viewer_metadata.role), so linking a newsletter does NOT grant verified
# ownership (confianzaScore 95 / admin_directo / auto-claim) by default — it
# links for metric polling with a soft score (30) and flags for manual review.
# Set to 'true' ONLY after the ownership redesign lands (MANUAL_ACTIONS.md §B3).
BAILEYS_TRUSTED_OWNERSHIP=false


# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=replace_me
DISCORD_CLIENT_ID=replace_me
DISCORD_CLIENT_SECRET=replace_me


# ── Instagram (legacy + new OAuth) ────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# OAuth flow used by the new onboarding wizard
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=


# ── Meta (Facebook Login for Business) ────────────────────────────────────────
# [required-feature] Required for WhatsApp webhook signature verification.
META_APP_ID=
META_APP_SECRET=


# ── LinkedIn ──────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=


# ── Google OAuth (sign-in with Google) ────────────────────────────────────────
GOOGLE_CLIENT_ID=
# Same value as GOOGLE_CLIENT_ID — exposed to the React bundle so the @react-oauth/google
# provider in client/src/App.jsx can initialize. Without it, Google sign-in is hidden.
VITE_GOOGLE_CLIENT_ID=

# ── Push notifications (web-push, optional) ───────────────────────────────────
# Generate the keypair with: npx web-push generate-vapid-keys
# Public key is exposed to the browser; private key only goes to the backend.
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@channelad.io


# ── Bot integration ──────────────────────────────────────────────────────────
# [CRITICAL] Long-lived API key the Telegram calculator bot uses to call
# /api/auth/bot-token. Rotate if leaked.
BOT_API_KEY=replace_with_64_byte_hex_secret


# ── Beta / full access ────────────────────────────────────────────────────────
# Comma-separated emails granted automatic dashboard access without paying.
# Leave EMPTY in shared environments — defaults include sample addresses that
# could be claimed by anyone who registers them.
FULL_ACCESS_EMAILS=


# ── Demo mode ─────────────────────────────────────────────────────────────────
DEMO_MODE=false
DEMO_PASSWORD=demo


# ── Sentry (error tracking) ───────────────────────────────────────────────────
# Required in production for error tracking. lib/sentry.js no-ops when empty,
# so leaving these blank in dev/CI is safe.
SENTRY_DSN=
VITE_SENTRY_DSN=
# Optional tuning
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# ── Cloudflare R2 (storage de media de campaña) ───────────────────────────────
# Bucket S3-compatible donde se suben imágenes/vídeos/documentos que los
# advertisers adjuntan a las campañas. Las URLs públicas se persisten en
# campaign.media[].url y los conectores de cada plataforma (Telegram,
# Discord, etc.) las descargan al publicar. Si dejas estas variables
# vacías, el endpoint POST /api/uploads/campaign-media devuelve 503 con
# `code: STORAGE_NOT_CONFIGURED` y el wizard puede aún funcionar para
# campañas de texto plano.
#
# Cómo crearlas:
#   1. Cloudflare dashboard → R2 → Create bucket (nombre = R2_BUCKET).
#   2. R2 → API Tokens → Create token con permiso "Object Read/Write"
#      acotado al bucket. Copia los Access Key ID + Secret.
#   3. R2_ACCOUNT_ID lo encuentras en el dashboard de R2, arriba a la dcha.
#   4. R2_PUBLIC_URL: usa el `xxx.r2.dev` del bucket para dev, o un
#      dominio custom (recomendado en producción) mapeado al bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=channelad-media
R2_PUBLIC_URL=
