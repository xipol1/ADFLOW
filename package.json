    "start": "node server.js",
    "dev": "nodemon server.js",
    "frontend:dev": "vite",
    "frontend:build": "node -e \"const fs=require('fs');const cp=require('child_process');if(!fs.existsSync('index.html')){console.log('Skipping vite build (index.html missing)');process.exit(0)}cp.execSync('npx vite build',{stdio:'inherit',shell:true})\"",
    "frontend:preview": "vite preview",
    "dev:full": "concurrently \"npm run dev\" \"npm run frontend:dev\"",
    "blog:build": "node scripts/build-blog.js",
    "build": "npm run blog:build && npm run frontend:build",
    "build:full": "npm run build && npm start",
    "migrate:roles": "node scripts/migrate-roles.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
