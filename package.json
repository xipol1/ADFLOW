  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "frontend:dev": "vite",
    "frontend:build": "node -e \"const fs=require('fs');const cp=require('child_process');if(!fs.existsSync('client/index.html')){console.log('Skipping vite build (client/index.html missing)');process.exit(0)}cp.execSync('npx vite build',{stdio:'inherit',shell:true})\"",
    "frontend:preview": "vite preview",
    "dev:full": "concurrently \"npm run dev\" \"npm run frontend:dev\"",
    "blog:build": "node scripts/build-blog.js",
    "prerender": "node scripts/prerender-routes.js",
    "snapshot:home": "npm run frontend:build && node scripts/snapshot-home.js",
    "build": "npm run blog:build && npm run frontend:build && npm run prerender",
    "build:full": "npm run build && npm start",
    "migrate:roles": "node scripts/migrate-roles.js",
    "errors:tail": "node scripts/tail-errors.js",
    "errors:watch": "node scripts/tail-errors.js --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
